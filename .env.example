# Copy this file to .env and fill in your key — do not rename it, the template
# itself is committed so others know which variables to set. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model used by the LLM interface layer.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional: point MLflow at a different tracking store.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
